# ─── Database ────────────────────────────────────────────────────────────────
# Pooled connection (used at runtime via PrismaPg adapter)
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
# Direct connection (used for migrations)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (server-side and client-side must match)
SUPABASE_STORAGE_BUCKET=deliveries
NEXT_PUBLIC_SUPABASE_BUCKET=deliveries

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard → Products
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=ApproveFlow <noreply@yourdomain.com>

# ─── App URL ─────────────────────────────────────────────────────────────────
# Full public URL of your deployment — no trailing slash
NEXT_PUBLIC_APP_URL=https://yourdomain.com
