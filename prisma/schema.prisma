// This is your Prisma schema file
// Prisma 7 — connection URLs moved to prisma.config.ts
// Learn more: https://pris.ly/d/prisma7-client-config

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── NextAuth required models ────────────────────────────────────────────────

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String    @unique
    emailVerified DateTime?
    image         String?
    password      String? // hashed — null for OAuth users
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    accounts Account[]
    sessions Session[]
    projects Project[]
}

model Account {
    id                String   @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?  @db.Text
    access_token      String?  @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?  @db.Text
    session_state     String?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@unique([identifier, token])
}

// ─── ApproveFlow domain models ───────────────────────────────────────────────

model Project {
    id          String   @id @default(cuid())
    userId      String
    name        String
    clientName  String
    clientEmail String?
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    deliveries Delivery[]
}

model Delivery {
    id            String         @id @default(cuid())
    projectId     String
    versionNumber Int
    label         String? // e.g. "Color adjustments"
    filePath      String // Supabase Storage path
    fileName      String
    fileSize      Int // bytes
    mimeType      String
    reviewToken   String         @unique
    status        DeliveryStatus @default(PENDING)
    expiresAt     DateTime?
    requiresEmail Boolean        @default(false)
    allowDownload Boolean        @default(true)
    password      String? // optional link password (hashed)
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
    comments Comment[]
    views    View[]
    approval Approval?
}

model Comment {
    id          String     @id @default(cuid())
    deliveryId  String
    authorType  AuthorType
    authorName  String
    authorEmail String?
    content     String     @db.Text
    // Normalized image coordinates (0–1). null = general comment
    xPosition   Float?
    yPosition   Float?
    createdAt   DateTime   @default(now())

    delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model View {
    id         String   @id @default(cuid())
    deliveryId String
    ipAddress  String?
    userAgent  String?
    createdAt  DateTime @default(now())

    delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model Approval {
    id          String   @id @default(cuid())
    deliveryId  String   @unique
    signerName  String
    signerEmail String?
    ipAddress   String?
    createdAt   DateTime @default(now())

    delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum DeliveryStatus {
    PENDING
    APPROVED
    CHANGES_REQUESTED
}

enum AuthorType {
    CLIENT
    FREELANCER
}

// ─── Guest (anonymous) uploads ───────────────────────────────────────────────

model GuestUpload {
    id              String         @id @default(cuid())
    filePath        String
    fileName        String
    fileSize        Int
    mimeType        String
    reviewToken     String         @unique
    claimToken      String         @unique
    status          DeliveryStatus @default(PENDING)
    expiresAt       DateTime
    claimedByUserId String?
    createdAt       DateTime       @default(now())

    comments GuestComment[]
    views    GuestView[]
}

model GuestComment {
    id            String     @id @default(cuid())
    guestUploadId String
    authorType    AuthorType @default(CLIENT)
    authorName    String
    content       String     @db.Text
    xPosition     Float?
    yPosition     Float?
    createdAt     DateTime   @default(now())

    guestUpload GuestUpload @relation(fields: [guestUploadId], references: [id], onDelete: Cascade)
}

model GuestView {
    id            String   @id @default(cuid())
    guestUploadId String
    ipAddress     String?
    userAgent     String?
    createdAt     DateTime @default(now())

    guestUpload GuestUpload @relation(fields: [guestUploadId], references: [id], onDelete: Cascade)
}
